{
  "name": "consent-management-api-cdk",
  "version": "0.1.0",
  "bin": {
    "consent-management-api-cdk": "bin/buildCdkStacks.js"
  },
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "clean": "rm -rf dist cdk.out node_modules",
    "prebuild": "bash ./bin/updateConsentManagementOpenApiSpec.sh && bash ./bin/updateConsentHistoryOpenApiSpec.sh",
    "test": "npm run build && jest",
    "update-snapshots": "npm run build && jest -u",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.9",
    "aws-cdk": "^2.1108.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "~2.241",
    "cdk-monitoring-constructs": "^9.19.3",
    "constructs": "^10.5.1"
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  }
}
